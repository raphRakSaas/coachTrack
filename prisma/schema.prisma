generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── COACH ───────────────────────────────────────────────────────────────────

model User {
  id                    String   @id @default(cuid())
  clerkId               String   @unique
  email                 String   @unique
  name                  String?
  specialty             String?
  bio                   String?
  yearsExperience       Int?
  onboardingCompleted   Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  clients             Client[]
  programs            Program[]
  sessions            Session[]
  exercises           Exercise[]
  subscription        Subscription?
  measurements        BodyMeasurement[]
  clientNotes         ClientNote[]
  trackingItems       TrackingItem[]
  clientPainNotes     ClientPainNote[]
  nutritionDayLogs    NutritionDayLog[]
}

// ─── CLIENT ──────────────────────────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ELITE
}

enum GoalType {
  WEIGHT_LOSS
  MUSCLE_GAIN
  PERFORMANCE
  ENDURANCE
  WELLBEING
  REHABILITATION
}

enum ProspectStatus {
  NEW
  CONTACTED
  HOT
  COLD
  CONVERTED
  LOST
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum BodyType {
  ECTOMORPH
  MESOMORPH
  ENDOMORPH
}

enum DietaryPreferences {
  STANDARD
  VEGETARIAN
  VEGAN
  GLUTEN_FREE
  LACTOSE_FREE
}

enum TrackingItemType {
  BILAN
  HABITUDE
  QUESTIONNAIRE
  MESURE
}

model Client {
  id       String @id @default(cuid())
  coachId  String
  coach    User   @relation(fields: [coachId], references: [id], onDelete: Cascade)

  // Identité
  firstName        String
  lastName         String
  email            String?
  phone            String?
  phoneCountryCode String?      @default("+33")
  gender           Gender?
  birthDate        DateTime?

  // Physique
  height Float? // cm

  // Profil sportif
  fitnessLevel    FitnessLevel @default(BEGINNER)
  weeklyFrequency Int?
  activityLevel   ActivityLevel?

  // Style de vie
  bodyType            BodyType?
  dietaryPreferences  DietaryPreferences?
  hasTCA              Boolean  @default(false)

  // Objectifs
  goalType             GoalType?
  goal                 String?
  goalTargetWeight     Float? // kg — poids cible
  goalDeadline         DateTime?
  coachingStartDate    DateTime?
  weightStart          Float? // kg — poids de départ explicite
  goalWeeklyLoss       Float? // kg/semaine visé

  // Nutrition — objectifs journaliers
  dailyCaloriesGoal    Int?
  dailyWaterGoal       Float? // litres
  // Répartition calories par repas (% )
  mealBreakfastPct     Int?   @default(25)
  mealLunchPct         Int?   @default(40)
  mealDinnerPct        Int?   @default(30)
  mealSnackPct         Int?   @default(5)
  // Macronutriments (%)
  macrosCarbsPct       Int?   @default(50)
  macrosProteinsPct    Int?   @default(20)
  macrosFatsPct        Int?   @default(30)

  // Médical
  injuries     String?
  medicalNotes String?

  /// Horodatage : le coach confirme une base légale explicite pour ces données sensibles (voir politique de confidentialité).
  sensitiveDataConsentAt DateTime?

  // Coordonnées
  company    String?
  address    String?
  postalCode String?
  city       String?
  country    String?   @default("France")

  // Réseaux sociaux
  linkedin  String?
  instagram String?
  facebook  String?
  twitter   String?

  // Préférences
  language String?   @default("fr")
  timezone String?   @default("Europe/Paris")

  // Administratif
  contractStart DateTime?
  hourlyRate    Float?
  notes         String?

  // Prospect pipeline
  isProspect      Boolean         @default(false)
  prospectStatus  ProspectStatus?
  prospectSource  String?
  prospectNotes   String?

  /// Client fictif créé pour chaque coach (même scénario pour tous ; pas une ligne partagée entre comptes).
  isDemo    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  programs      Program[]
  sessions      Session[]
  measurements  BodyMeasurement[]
  clientNotes        ClientNote[]
  trackingItems      TrackingItem[]
  painNotes          ClientPainNote[]
  nutritionDayLogs   NutritionDayLog[]

  @@index([coachId, isDemo])
}

// ─── DOULEURS (zones musculaires — données potentiellement sensibles) ────────

model ClientPainNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  coachId   String
  coach     User     @relation(fields: [coachId], references: [id], onDelete: Cascade)

  regionKey String
  note      String   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, regionKey])
  @@index([coachId])
}

// ─── JOURNAL NUTRITION QUOTIDIEN (récap coach / client) ──────────────────────

model NutritionDayLog {
  id               String   @id @default(cuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  coachId          String
  coach            User     @relation(fields: [coachId], references: [id], onDelete: Cascade)

  /// Jour civil (sans heure significative — stockage à midi UTC recommandé côté app)
  date             DateTime @db.Date
  caloriesConsumed Int
  proteinG         Float?
  carbsG           Float?
  fatG             Float?
  waterL           Float?
  breakfastKcal    Int?
  lunchKcal        Int?
  dinnerKcal       Int?
  snackKcal        Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, date])
  @@index([clientId])
}

// ─── NOTES CLIENT ─────────────────────────────────────────────────────────────

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  coachId   String
  coach     User     @relation(fields: [coachId], references: [id], onDelete: Cascade)

  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// ─── SUIVI (TRACKING) ────────────────────────────────────────────────────────

model TrackingItem {
  id          String           @id @default(cuid())
  clientId    String
  client      Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  coachId     String
  coach       User             @relation(fields: [coachId], references: [id], onDelete: Cascade)

  type        TrackingItemType
  name        String
  description String?
  frequency   String?          // "daily", "weekly", "monthly", "once"
  isActive    Boolean          @default(true)
  lastAnsweredAt DateTime?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([clientId])
}

// ─── MESURES CORPORELLES ─────────────────────────────────────────────────────

model BodyMeasurement {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  coachId  String
  coach    User   @relation(fields: [coachId], references: [id], onDelete: Cascade)

  date       DateTime @default(now())
  weight     Float? // kg
  bodyFat    Float? // %
  muscleMass Float? // kg
  waist      Float? // cm
  hips       Float? // cm
  chest      Float? // cm
  leftArm    Float? // cm
  rightArm   Float? // cm
  leftThigh  Float? // cm
  rightThigh Float? // cm
  notes      String?

  createdAt DateTime @default(now())
}

// ─── BIBLIOTHÈQUE D'EXERCICES ────────────────────────────────────────────────

model Exercise {
  id          String      @id @default(cuid())
  coachId     String?
  coach       User?       @relation(fields: [coachId], references: [id])

  name        String
  muscleGroup MuscleGroup
  description String?
  imageUrl    String?
  imagePublicId String?
  sourceExerciseId String?
  sourceExercise   Exercise? @relation("ExerciseSource", fields: [sourceExerciseId], references: [id], onDelete: SetNull)
  derivedExercises Exercise[] @relation("ExerciseSource")
  isGlobal    Boolean     @default(false)

  programExercises ProgramExercise[]
  sessionExercises SessionExercise[]

  @@index([coachId])
  @@index([isGlobal])
  @@index([muscleGroup])
  @@unique([coachId, name])
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  LEGS
  GLUTES
  ABS
  CARDIO
  FULL_BODY
}

// ─── PROGRAMME ───────────────────────────────────────────────────────────────

model Program {
  id          String    @id @default(cuid())
  coachId     String
  coach       User      @relation(fields: [coachId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isActive    Boolean   @default(true)
  startDate   DateTime  @default(now())
  endDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workoutDays WorkoutDay[]
}

model WorkoutDay {
  id        String  @id @default(cuid())
  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  dayNumber Int
  name      String

  exercises ProgramExercise[]
}

model ProgramExercise {
  id           String     @id @default(cuid())
  workoutDayId String
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  exerciseId   String
  exercise     Exercise   @relation(fields: [exerciseId], references: [id])

  sets     Int
  reps     String
  weight   Float?
  restTime Int?
  notes    String?
  order    Int
}

// ─── SÉANCE ──────────────────────────────────────────────────────────────────

model Session {
  id       String @id @default(cuid())
  coachId  String
  coach    User   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  date     DateTime
  duration Int?
  notes    String?
  rpe      Int? // 1-10 effort perçu
  mood     Int? // 1-5 humeur client
  energy   Int? // 1-5 énergie client

  /// Lieu (salle, domicile, extérieur…)
  location String?
  /// Objectif ou thème court (ex. tirage, jambes, mobilité)
  sessionFocus String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exercises SessionExercise[]
}

model SessionExercise {
  id         String   @id @default(cuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  order Int
  notes String?

  sets SessionSet[]
}

model SessionSet {
  id                String          @id @default(cuid())
  sessionExerciseId String
  sessionExercise   SessionExercise @relation(fields: [sessionExerciseId], references: [id], onDelete: Cascade)

  setNumber Int
  reps      Int?
  weight    Float?
  duration  Int?
  completed Boolean @default(true)
  notes     String?
}

// ─── ABONNEMENT STRIPE ───────────────────────────────────────────────────────

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(TRIALING)
  plan                 Plan               @default(FREE)
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum Plan {
  FREE
  PRO
}
